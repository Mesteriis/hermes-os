{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@11.5.1",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"lint": "pnpm lint:styles && pnpm lint:ts",
		"lint:styles": "node scripts/check-no-inline-styles.mjs",
		"lint:ts": "svelte-kit sync && svelte-check --fail-on-warnings --tsconfig ./tsconfig.json",
		"capture:layout": "node scripts/capture-layout-screenshots.mjs",
		"test:layout": "vitest run src/lib/layout",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "pnpm lint && pnpm test:layout",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tauri-apps/cli": "^2.11.2",
		"@types/node": "^25.9.1",
		"playwright": "^1.60.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@iconify/svelte": "^5.2.1"
	}
}
