{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@11.5.1",
	"scripts": {
		"dev": "vite",
		"proto:generate": "node scripts/generate-proto.mjs",
		"build": "pnpm typecheck && vite build",
		"typecheck": "vue-tsc --noEmit",
		"lint:ox": "oxlint --vue-plugin .",
		"lint:styles": "node scripts/check-no-inline-styles.mjs",
		"lint:srp": "node scripts/check-component-lines.mjs",
		"lint:vue-boundaries": "node scripts/check-vue-component-boundaries.mjs",
		"lint": "pnpm lint:ox && pnpm lint:styles && pnpm lint:srp && pnpm lint:vue-boundaries",
		"preview": "vite preview",
		"test": "pnpm test:unit",
		"test:unit": "vitest run",
		"test:visual": "playwright test",
		"test:visual:update": "playwright test --update-snapshots",
		"validate": "pnpm lint && pnpm typecheck && pnpm test:unit && pnpm test:visual && pnpm build",
		"storybook": "storybook dev -p 6006",
		"storybook:build": "storybook build",
		"storybook:serve": "node scripts/serve-storybook-static.mjs",
		"storybook:test": "test-storybook --url http://localhost:6006"
	},
	"devDependencies": {
		"@bufbuild/protoc-gen-es": "^2.12.0",
		"@playwright/test": "^1.61.1",
		"@storybook/addon-a11y": "^10.0.0",
		"@storybook/addon-coverage": "^3.0.1",
		"@storybook/addon-designs": "^11.1.3",
		"@storybook/addon-docs": "^10.0.0",
		"@storybook/addon-themes": "^10.4.6",
		"@storybook/addon-vitest": "^10.4.6",
		"@storybook/test-runner": "^0.24.4",
		"@storybook/vue3-vite": "^10.0.0",
		"@tauri-apps/cli": "^2.11.2",
		"@types/node": "^25.9.1",
		"@vitejs/plugin-vue": "^6.0.7",
		"autoprefixer": "^10.4.20",
		"msw": "^2.14.6",
		"msw-storybook-addon": "^2.0.7",
		"oxlint": "^1.70.0",
		"postcss": "^8.5.3",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"storybook": "^10.0.0",
		"storybook-addon-pseudo-states": "^10.4.6",
		"storybook-design-token": "^5.0.0",
		"tailwindcss": "^3.4.17",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.8",
		"vue-tsc": "^2.2.8"
	},
	"dependencies": {
		"@bufbuild/protobuf": "^2.12.0",
		"@connectrpc/connect": "^2.1.2",
		"@connectrpc/connect-web": "^2.1.2",
		"@iconify/vue": "^4.3.0",
		"@tanstack/vue-query": "^5.101.0",
		"@tanstack/vue-table": "^8.21.3",
		"@tanstack/vue-virtual": "^3.13.28",
		"@tauri-apps/api": "^2.11.1",
		"@tiptap/vue-3": "^3.26.1",
		"@vee-validate/zod": "^4.15.1",
		"@vue-flow/core": "^1.48.2",
		"@vueuse/core": "^14.3.0",
		"date-fns": "^4.4.0",
		"dompurify": "^3.4.11",
		"highlight.js": "^11.11.1",
		"marked": "^18.0.5",
		"motion-v": "^2.3.0",
		"pinia": "^3.0.4",
		"reka-ui": "^2.9.10",
		"vee-validate": "^4.15.1",
		"vue": "^3.5.38",
		"vue-router": "^4.5.0",
		"zod": "^3.25.76"
	},
	"msw": {
		"workerDirectory": [
			"public"
		]
	}
}
