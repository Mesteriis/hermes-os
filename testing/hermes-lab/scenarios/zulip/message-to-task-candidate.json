{
  "scenario_id": "zulip_message_to_task_candidate",
  "provider": "zulip",
  "description": "Send a task-like Zulip message and trace it from provider observation toward Review/Tasks.",
  "correlation_id_prefix": "lab-zulip-task",
  "event_types": [
    "message",
    "reaction",
    "update_message",
    "delete_message"
  ],
  "actions": [
    {
      "kind": "send_stream_message",
      "stream": "Hermes Lab",
      "topic": "Tasks",
      "content": "Надо проверить backup retention до пятницы. Trace={{correlation_id}}"
    },
    {
      "kind": "add_reaction",
      "message_id_ref": "last",
      "emoji_name": "thumbs_up",
      "emoji_code": "1f44d",
      "reaction_type": "unicode_emoji"
    },
    {
      "kind": "update_message",
      "message_id_ref": "last",
      "updated_content": "Надо проверить backup retention и назначить owner до пятницы. Trace={{correlation_id}}"
    },
    {
      "kind": "upload_file",
      "filename": "hermes-lab-evidence.txt",
      "file_content": "Hermes Lab evidence {{correlation_id}}"
    },
    {
      "kind": "delete_message",
      "message_id_ref": "last"
    }
  ],
  "expect": [
    "signal.raw.zulip.message.observed",
    "signal.raw.zulip.reaction.observed",
    "signal.raw.zulip.message_update.observed",
    "signal.raw.zulip.message_delete.observed"
  ],
  "backend_expected_stages": [
    "signal.accepted.zulip.message",
    "communication.message.recorded",
    "task_candidates",
    "review_items",
    "signal.accepted.zulip.reaction",
    "communication_message_reactions",
    "communication.message.updated",
    "signal.accepted.zulip.message_update",
    "communication_message_versions",
    "signal.accepted.zulip.message_delete",
    "communication_message_tombstones"
  ],
  "capability_contract": [
    {
      "name": "receive.message.recorded",
      "status": "backend_test_required",
      "evidence": "backend/tests/zulip.rs::zulip_raw_signal_projects_message_and_is_idempotent"
    },
    {
      "name": "mutation.reaction.materialized",
      "status": "backend_test_required",
      "evidence": "backend/tests/zulip.rs::zulip_reaction_edit_delete_signals_materialize_canonical_state"
    },
    {
      "name": "mutation.edit.materialized",
      "status": "backend_test_required",
      "evidence": "backend/tests/zulip.rs::zulip_reaction_edit_delete_signals_materialize_canonical_state"
    },
    {
      "name": "mutation.delete.materialized",
      "status": "backend_test_required",
      "evidence": "backend/tests/zulip.rs::zulip_reaction_edit_delete_signals_materialize_canonical_state"
    },
    {
      "name": "review.task_candidate.detected",
      "status": "backend_test_required",
      "evidence": "backend/tests/zulip.rs::zulip_message_can_feed_review_task_candidate_without_auto_creating_task"
    },
    {
      "name": "provider_api.send_stream_direct",
      "status": "backend_test_required",
      "evidence": "backend/tests/zulip.rs::zulip_api_client_supports_message_lifecycle_reactions_and_uploads"
    },
    {
      "name": "provider_api.edit_delete_reaction",
      "status": "backend_test_required",
      "evidence": "backend/tests/zulip.rs::zulip_api_client_supports_message_lifecycle_reactions_and_uploads"
    },
    {
      "name": "provider_api.upload_file",
      "status": "backend_test_required",
      "evidence": "backend/tests/zulip.rs::zulip_api_client_supports_message_lifecycle_reactions_and_uploads"
    },
    {
      "name": "provider_command.durable_lifecycle",
      "status": "backend_test_required",
      "evidence": "backend/tests/zulip.rs::zulip_provider_commands_are_durable_idempotent_and_retryable"
    },
    {
      "name": "provider_command.executes_stream_send",
      "status": "backend_test_required",
      "evidence": "backend/tests/zulip.rs::zulip_command_worker_executes_due_stream_command_with_resolved_api_key"
    },
    {
      "name": "provider_command.failure_redaction",
      "status": "backend_test_required",
      "evidence": "backend/tests/zulip.rs::zulip_command_worker_sanitizes_provider_errors_before_retrying"
    },
    {
      "name": "provider_command.scheduler_ready",
      "status": "source_check_required",
      "evidence": "backend/src/application/bootstrap.rs::start_zulip_command_executor"
    },
    {
      "name": "media.attachment.materialized",
      "status": "backend_test_required",
      "evidence": "backend/tests/zulip.rs::zulip_attachment_download_worker_materializes_pending_user_upload"
    },
    {
      "name": "media.attachment.scheduler_ready",
      "status": "source_check_required",
      "evidence": "backend/src/application/bootstrap.rs::start_zulip_attachment_download"
    }
  ],
  "backend_validation": {
    "status": "not_run_by_lab",
    "command": "cargo test --manifest-path backend/Cargo.toml --test zulip"
  },
  "notes": [
    "Phase 1 validates provider send/observe and writes a local report.",
    "Backend validation is intentionally a separate command; Lab reports do not claim backend stages were observed unless a runner executes them."
  ]
}
