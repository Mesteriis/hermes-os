{
  "scenario_id": "zulip_attachment_materialization",
  "provider": "zulip",
  "description": "Upload a file, send a Zulip stream message containing the upload URI, and verify same-realm download metadata without storing bytes in the Lab report.",
  "correlation_id_prefix": "lab-zulip-attachment",
  "event_types": [
    "message"
  ],
  "actions": [
    {
      "kind": "send_stream_message_with_upload",
      "stream": "Hermes Lab",
      "topic": "Attachments",
      "content": "См. вложение для Hermes Lab. Trace={{correlation_id}}",
      "filename": "hermes-lab-evidence.txt",
      "file_content": "Hermes Lab attachment evidence {{correlation_id}}"
    },
    {
      "kind": "download_user_upload",
      "upload_uri_ref": "last"
    }
  ],
  "expect": [
    "signal.raw.zulip.message.observed"
  ],
  "backend_expected_stages": [
    "signal.accepted.zulip.message",
    "communication.message.recorded",
    "zulip_attachment_metadata",
    "communication_attachments",
    "attachment_state.materialized"
  ],
  "capability_contract": [
    {
      "name": "provider_api.upload_file",
      "status": "backend_test_required",
      "evidence": "backend/tests/zulip.rs::zulip_api_client_supports_message_lifecycle_reactions_and_uploads"
    },
    {
      "name": "provider_api.download_user_upload",
      "status": "backend_test_required",
      "evidence": "backend/tests/zulip.rs::zulip_api_client_supports_message_lifecycle_reactions_and_uploads"
    },
    {
      "name": "lab.provider_send_stream_with_upload",
      "status": "execute_required",
      "evidence": "make hermes-lab ACTION=scenario PROVIDER=zulip EXECUTE=1 SCENARIO=testing/hermes-lab/scenarios/zulip/attachment-materialization.json"
    },
    {
      "name": "media.attachment.materialized",
      "status": "backend_test_required",
      "evidence": "backend/tests/zulip.rs::zulip_attachment_download_worker_materializes_pending_user_upload"
    },
    {
      "name": "media.attachment.scheduler_ready",
      "status": "source_check_required",
      "evidence": "backend/src/application/bootstrap.rs::start_zulip_attachment_download"
    }
  ],
  "backend_validation": {
    "status": "not_run_by_lab",
    "command": "cargo test --manifest-path backend/Cargo.toml --test zulip"
  },
  "notes": [
    "The Lab report stores upload URI, content type, byte count and sha256 only; it must not store file bytes.",
    "Backend validation is intentionally separate from provider execution unless a runner wires Hermes backend state into the Lab session."
  ]
}
