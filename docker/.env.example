HERMES_POSTGRES_DB=hermes_hub
HERMES_POSTGRES_USER=hermes
HERMES_POSTGRES_PASSWORD=change-me-local-dev-only
HERMES_POSTGRES_BIND=127.0.0.1
HERMES_POSTGRES_PORT=30432
HERMES_NATS_BIND=127.0.0.1
HERMES_NATS_PORT=34222
HERMES_NATS_MONITOR_BIND=127.0.0.1
HERMES_NATS_MONITOR_PORT=38222
HERMES_NATS_SERVER_URL=nats://127.0.0.1:34222
HERMES_BACKEND_BIND=127.0.0.1
HERMES_BACKEND_PORT=8080
HERMES_FRONTEND_BIND=127.0.0.1
HERMES_FRONTEND_PORT=5174
HERMES_LOCAL_API_SECRET=change-me-local-api-secret
HERMES_DEV_MODE=true
HERMES_HOST_VAULT_HOME=${HOME}/.hermes/vault
HERMES_VAULT_HOME=/hermes-vault
HERMES_DEV_KEY_PATH=/hermes-vault/dev/master.key
HERMES_SECRET_VAULT_KEY=change-me-local-secret-vault-key
# Optional WhatsApp Business Cloud public edge proxy for webhook forwarding.
# This service is profile-gated and keeps Hermes itself behind X-Hermes-Secret.
HERMES_WHATSAPP_BUSINESS_CLOUD_EDGE_BIND=127.0.0.1
HERMES_WHATSAPP_BUSINESS_CLOUD_EDGE_PORT=8787
HERMES_WHATSAPP_BUSINESS_CLOUD_EDGE_HERMES_BASE_URL=http://host.docker.internal:8080
# HERMES_WHATSAPP_BUSINESS_CLOUD_EDGE_ACCOUNT_ID=optional-account-scope
# HERMES_WHATSAPP_BUSINESS_CLOUD_EDGE_RUST_LOG=info
# Optional native TDLib JSON runtime path, for example:
# HERMES_TDJSON_PATH=/opt/homebrew/lib/libtdjson.dylib
# Optional Telegram app credentials for local TDLib login flows:
# HERMES_TELEGRAM_API_ID=123456
# HERMES_TELEGRAM_API_HASH=replace-with-telegram-api-hash
# Optional Google OAuth client credentials for one-click Gmail, Calendar and Contacts setup.
# Prefer the downloaded Desktop app JSON path for packaged/local desktop OAuth config:
# HERMES_GOOGLE_OAUTH_CLIENT_CONFIG_PATH=/absolute/path/to/client_secret.json
# Or use explicit runtime overrides:
# HERMES_GOOGLE_OAUTH_CLIENT_ID=replace-with-google-oauth-client-id
# HERMES_GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-oauth-client-secret
HERMES_OLLAMA_BASE_URL=http://127.0.0.1:11434
HERMES_OLLAMA_CHAT_MODEL=qwen3:4b
HERMES_OLLAMA_EMBED_MODEL=qwen3-embedding:4b
HERMES_OLLAMA_TIMEOUT_SECONDS=120
